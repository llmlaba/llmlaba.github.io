{
  "name": "llmlaba-github-io",
  "description": "LLM Laboratory — Jekyll site with Tailwind CSS + Webpack + GLightbox",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:front": "webpack --mode production",
    "build": "npm run build:front && bundle exec jekyll build",
    "dev:front": "webpack --watch --mode development",
    "dev:jekyll": "bundle exec jekyll serve --livereload --host 0.0.0.0",
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:jekyll\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.10.0",
    "mini-css-extract-plugin": "^2.8.0",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.1.0",
    "tailwindcss": "^3.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "glightbox": "^3.3.0",
    "prismjs": "^1.30.0"
  }
}
